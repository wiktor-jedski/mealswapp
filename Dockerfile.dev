FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

# System dependencies
RUN apt-get update && apt-get install -y \
    git \
    gh \
    sudo \
    curl \
    wget \
    unzip \
    build-essential \
    postgresql \
    postgresql-contrib \
    redis-server \
    golang-go \
    coinor-libclp-dev \
    coinor-clp \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Set up user
RUN mkdir -p /home/ubuntu/.local/share/opencode \
    && chown -R ubuntu:ubuntu /home/ubuntu/.local
RUN mkdir -p /home/ubuntu/.config/opencode \
    && chown -R ubuntu:ubuntu /home/ubuntu/.config
RUN usermod -aG sudo ubuntu \
    && echo "ubuntu ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/ubuntu \
    && chmod 0440 /etc/sudoers.d/ubuntu
USER ubuntu

# Install opencode
RUN curl -fsSL https://opencode.ai/install | bash

# Install Bun
RUN curl -fsSL https://bun.sh/install | bash

# Set up environment
ENV PATH="$PATH:/root/go/bin:/home/ubuntu/.local/bin:/home/ubuntu/.bun/bin:/home/ubuntu/.opencode/bin"
ENV GOPATH="/root/go"

# Environment variables for the app
ENV DATABASE_URL="postgres://mealswapp:dev@localhost:5432/mealswapp?sslmode=disable"
ENV REDIS_URL="redis://localhost:6379"
ENV REPO_URL=""

# Copy start script
COPY --chmod=755 scripts/start_services.sh /start_services.sh

WORKDIR /workspace

ENTRYPOINT ["/start_services.sh"]
CMD []
