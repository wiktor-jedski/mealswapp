{
  "provider": "gcp-cloud-sql-postgres",
  "backup": {
    "enabled": true,
    "startTimeUtc": "03:00",
    "retentionDays": 30,
    "retainedBackups": 30,
    "pointInTimeRecovery": true,
    "transactionLogRetentionDays": 7
  },
  "restoreRehearsal": {
    "frequency": "monthly",
    "target": "staging-or-local",
    "requiredEvidence": [
      "backup_id",
      "restore_started_at",
      "restore_completed_at",
      "migration_check_result",
      "application_readiness_result"
    ]
  },
  "alerts": [
    "backup-verification-failed",
    "backup-retention-breach"
  ]
}
