{
  "name": "mealswapp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "generate:api-types": "python3 ../scripts/generate-api-types.py",
    "check:api-types": "python3 ../scripts/generate-api-types.py --check",
    "test": "bun test",
    "test:browser": "playwright test",
    "check": "bun run check:api-types && bun run build && bun test && bun run test:browser"
  },
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tanstack/svelte-query": "6.1.34",
    "svelte": "^5.45.4",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.61.0",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/svelte": "^5.2.9",
    "@types/bun": "^1.3.1",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3"
  }
}
